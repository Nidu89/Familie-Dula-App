{
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(vercel *)",
      "Bash(git *)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(python3:*)",
      "Read(//Users/niklasdula/Desktop/**)",
      "Edit(*)",
      "Write(*)",
      "mcp__supabase__*",
      "Agent(*)",
      "mcp__stitch__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-quality.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
